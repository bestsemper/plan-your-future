generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String            @id @default(cuid())
  computingId String            @unique
  displayName String
  password    String?
  school      String?
  major       String?
  additionalPrograms String[]   @default([])
  currentAcademicYear Int?
  gradYear    Int?
  bio         String?
  profileVisibility String       @default("hidden") // "hidden" or "public"
  anonymousMode     Boolean      @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  courses     CompletedCourse[]
  answers     ForumAnswer[]
  posts       ForumPost[]
  goalProfile GoalProfile?
  plans       Plan[]
  badges      UserBadge[]
  forumPostViews ForumPostView[]
  votes       Vote[]
  passwordResetTokens PasswordResetToken[]
}

model CompletedCourse {
  id            String  @id @default(cuid())
  userId        String
  courseCode    String
  title         String?
  sourceType    String
  semesterTaken String?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoalProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  studyAbroad     Boolean @default(false)
  doubleMajor     Boolean @default(false)
  earlyGraduation Boolean @default(false)
  gapYear         Boolean @default(false)
  notes           String?
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plan {
  id            String      @id @default(cuid())
  userId        String
  title         String
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  forumPosts    ForumPost[]
  forumAnswers  ForumAnswer[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  semesters     Semester[]
}

model Semester {
  id        String          @id @default(cuid())
  planId    String
  termName  String
  termOrder Int
  year      Int
  courses   PlannedCourse[]
  plan      Plan            @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model PlannedCourse {
  id         String   @id @default(cuid())
  semesterId String
  courseCode String
  title      String?
  creditsMin Int?
  creditsMax Int?
  locked     Boolean  @default(false)
  notes      String?
  semester   Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
}

model ForumPost {
  id             String        @id @default(cuid())
  postNumber     Int           @unique @default(autoincrement())
  authorId       String?
  title          String
  body           String
  attachedPlanId String?
  planSnapshot   Json?         // Snapshot of attached plan at time of posting
  viewCount      Int           @default(0)
  isAnonymous    Boolean       @default(true)
  tags           String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  answers        ForumAnswer[]
  attachedPlan   Plan?         @relation(fields: [attachedPlanId], references: [id])
  author         User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  views          ForumPostView[]
  votes          Vote[]
}

model ForumPostView {
  id           String    @id @default(cuid())
  postId       String
  userId       String?
  viewerToken  String?
  lastViewedAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  post         ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@unique([postId, viewerToken])
  @@index([userId])
  @@index([viewerToken])
}

model ForumAnswer {
  id             String    @id @default(cuid())
  postId         String
  authorId       String?
  parentId       String?
  body           String
  attachedPlanId String?
  planSnapshot   Json?     // Snapshot of attached plan at time of posting
  isAnonymous    Boolean   @default(true)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  author         User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  post           ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent         ForumAnswer?  @relation("ForumAnswerReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies        ForumAnswer[] @relation("ForumAnswerReplies")
  votes          Vote[]
  attachedPlan   Plan?     @relation(fields: [attachedPlanId], references: [id])

  @@index([postId, parentId])
}

model Vote {
  id       String       @id @default(cuid())
  userId   String
  answerId String?
  postId   String?
  value    Int
  answer   ForumAnswer? @relation(fields: [answerId], references: [id], onDelete: Cascade)
  post     ForumPost?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingSignup {
  id             String    @id @default(cuid())
  email          String    @unique
  computingId    String    @unique
  hashedPassword String
  displayName    String
  token          String    @unique
  expiresAt      DateTime
  createdAt      DateTime  @default(now())
  resendCount    Int       @default(0)
  lastResentAt   DateTime?
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
